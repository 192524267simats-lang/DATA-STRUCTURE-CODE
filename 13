#include<stdio.h>
#define SIZE 5

int queue[SIZE];
int front=-1,rear=-1;

void enqueue()
{
    int x;

    if(rear==SIZE-1)
        printf("Queue Full");

    else
    {
        printf("Enter value:");
        scanf("%d",&x);

        if(front==-1)
            front=0;

        queue[++rear]=x;
    }
}

void dequeue()
{
    if(front==-1 || front>rear)
        printf("Queue Empty");

    else
        printf("Deleted %d",queue[front++]);
}

void display()
{
    int i;

    for(i=front;i<=rear;i++)
        printf("%d ",queue[i]);
}

int main()
{
    int ch;

    do
    {
        printf("\n1.Enqueue\n2.Dequeue\n3.Display\n4.Exit");
        scanf("%d",&ch);

        switch(ch)
        {
            case 1:enqueue();break;
            case 2:dequeue();break;
            case 3:display();break;
        }

    }while(ch!=4);

    return 0;
}

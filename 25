#include<stdio.h>

int parent[20];

int find(int i)
{
    while(parent[i])
        i=parent[i];

    return i;
}

int main()
{
    int cost[20][20];
    int n,i,j,a,b,u,v,min,count=0,total=0;

    printf("Enter vertices:");
    scanf("%d",&n);

    printf("Enter cost matrix:");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    while(count<n-1)
    {
        min=999;

        for(i=0;i<n;i++)
            for(j=0;j<n;j++)
                if(cost[i][j]<min)
                {
                    min=cost[i][j];
                    a=u=i;
                    b=v=j;
                }

        u=find(u);
        v=find(v);

        if(u!=v)
        {
            printf("%d - %d = %d\n",a,b,min);
            total+=min;
            parent[v]=u;
            count++;
        }

        cost[a][b]=cost[b][a]=999;
    }

    printf("Total cost=%d",total);

    return 0;
}

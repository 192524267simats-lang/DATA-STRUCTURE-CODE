#include<stdio.h>

#define INF 999

int main()
{
    int graph[10][10],dist[10],visited[10];
    int n,i,j,start,min,u;

    printf("Enter vertices:");
    scanf("%d",&n);

    printf("Enter graph:");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    printf("Enter start vertex:");
    scanf("%d",&start);

    for(i=0;i<n;i++)
    {
        dist[i]=graph[start][i];
        visited[i]=0;
    }

    dist[start]=0;

    for(i=0;i<n;i++)
    {
        min=INF;

        for(j=0;j<n;j++)
        {
            if(!visited[j] && dist[j]<min)
            {
                min=dist[j];
                u=j;
            }
        }

        visited[u]=1;

        for(j=0;j<n;j++)
        {
            if(dist[u]+graph[u][j]<dist[j])
                dist[j]=dist[u]+graph[u][j];
        }
    }

    printf("Shortest distance:\n");

    for(i=0;i<n;i++)
        printf("%d -> %d\n",i,dist[i]);

    return 0;
}

#include<stdio.h>
#include<ctype.h>

char stack[50];
int top=-1;

void push(char x)
{
    stack[++top]=x;
}

char pop()
{
    return stack[top--];
}

int main()
{
    char exp[50],ch;
    int i;

    printf("Enter expression:");
    scanf("%s",exp);

    for(i=0;exp[i]!='\0';i++)
    {
        ch=exp[i];

        if(isalnum(ch))
            printf("%c",ch);

        else if(ch=='(')
            push(ch);

        else if(ch==')')
        {
            while(stack[top]!='(')
                printf("%c",pop());

            pop();
        }

        else
            push(ch);
    }

    while(top!=-1)
        printf("%c",pop());

    return 0;
}

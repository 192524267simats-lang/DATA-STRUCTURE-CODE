#include<stdio.h>

int main()
{
    int a[20],n,key,i;

    printf("Enter size:");
    scanf("%d",&n);

    printf("Enter elements:");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    printf("Enter search element:");
    scanf("%d",&key);

    for(i=0;i<n;i++)
    {
        if(a[i]==key)
        {
            printf("Found at position %d",i+1);
            return 0;
        }
    }

    printf("Not Found");

    return 0;
}

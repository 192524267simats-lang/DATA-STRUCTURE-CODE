#include<stdio.h>

int graph[10][10],visited[10];
int n;

void dfs(int v)
{
    int i;

    visited[v]=1;

    printf("%d ",v);

    for(i=0;i<n;i++)
    {
        if(graph[v][i] && !visited[i])
            dfs(i);
    }
}

int main()
{
    int i,j,start;

    printf("Enter number of vertices:");
    scanf("%d",&n);

    printf("Enter adjacency matrix:\n");

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&graph[i][j]);

    printf("Enter starting vertex:");
    scanf("%d",&start);

    printf("DFS Traversal:");

    dfs(start);

    return 0;
}

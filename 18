#include<stdio.h>

void quick(int a[],int low,int high)
{
    int i,j,pivot,temp;

    if(low<high)
    {
        pivot=a[low];
        i=low+1;
        j=high;

        while(i<=j)
        {
            while(a[i]<=pivot)
                i++;

            while(a[j]>pivot)
                j--;

            if(i<j)
            {
                temp=a[i];
                a[i]=a[j];
                a[j]=temp;
            }
        }

        temp=a[low];
        a[low]=a[j];
        a[j]=temp;

        quick(a,low,j-1);
        quick(a,j+1,high);
    }
}

int main()
{
    int a[50],n,i;

    printf("Enter size:");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    quick(a,0,n-1);

    printf("Sorted array:");

    for(i=0;i<n;i++)
        printf("%d ",a[i]);

    return 0;
}

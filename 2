#include<stdio.h>
int main()
{
    int n[10],i,size;

    printf("Enter size:");
    scanf("%d",&size);

    printf("Enter numbers:");
    for(i=0;i<size;i++)
        scanf("%d",&n[i]);

    for(i=0;i<size;i++)
    {
        if(n[i]%2==0)
            printf("%d is Even\n",n[i]);
        else
            printf("%d is Odd\n",n[i]);
    }
}
